# Copy to .env.local for local dev. Never commit real values.

# --- Supabase ---
# Server-only — never expose to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public — safe to expose, used by browser clients.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Resend ---
RESEND_API_KEY=
# Must be a verified sending domain in Resend.
RESEND_FROM_EMAIL="Fight Camp <hello@yourdomain.com>"
